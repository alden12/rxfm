{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run tsrx Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/tsrx/vscode-extension",
        "${workspaceFolder}",
        "${workspaceFolder}/tsrx/example.tsrx"
      ]
    }
  ]
}
