{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Reactive TS Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/reactive-ts/vscode-extension",
        "${workspaceFolder}",
        "${workspaceFolder}/reactive-ts/examples/example.rts"
      ]
    }
  ]
}
