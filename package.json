{
  "name": "rxfm",
  "version": "3.0.0-alpha.1",
  "author": "Alden Laslett",
  "description": "A Web Framework Built on RxJS",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alden12/rxfm.git"
  },
  "homepage": "https://github.com/alden12/rxfm",
  "keywords": [
    "RxJS",
    "Rx",
    "observable",
    "web",
    "framework",
    "reactive",
    "functional",
    "frontend"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "predev": "yarn build:reactive-ts",
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts",
    "prebuild:app": "yarn build:reactive-ts",
    "build:app": "vite build",
    "preview": "vite preview",
    "build:reactive-ts": "tsc -p reactive-ts/ts-plugin/tsconfig.json",
    "reactive-ts:emit": "yarn build:reactive-ts && node reactive-ts/emit.cjs",
    "dev:reactive-ts": "yarn build:reactive-ts && vite --config reactive-ts/vite.reactive-ts.config.ts",
    "build:reactive-ts-demo": "yarn build:reactive-ts && vite build --config reactive-ts/vite.reactive-ts.config.ts",
    "pretest": "tsc -p reactive-ts/ts-plugin/tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "extension:install-deps": "cd reactive-ts/vscode-extension && npm install",
    "extension:build": "cd reactive-ts/vscode-extension && npm run package",
    "extension:build-and-install": "cd reactive-ts/vscode-extension && npm run reinstall",
    "extension:bump-version": "cd reactive-ts/vscode-extension && npm run bump"
  },
  "peerDependencies": {
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.0",
    "highlight.js": "^11.11.1",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "marked": "^18.0.5",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0"
  }
}
