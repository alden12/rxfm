{
    "compilerOptions": {
        "strict": true,
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "sourceMap": true,
        "declaration": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "rxfm": ["src/lib/rxfm/index"]
        }
    },
    "exclude": [
        "node_modules",
        "dist",
        "dist-demo",
        "tsrx",
        "**/*.test.ts"
    ]
}
