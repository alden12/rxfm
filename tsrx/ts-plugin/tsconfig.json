{
  // Builds the tsrx transform from its TypeScript source (transform.cts) to the
  // CommonJS transform.cjs that the tsserver plugin, the Volar language plugin and
  // the fixture harness all require(). `.cts` in → `.cjs` out (tsc honours the
  // explicit CommonJS extension), so the emitted filename is exactly what the
  // existing consumers already load.
  //
  // `import type * as TS from 'typescript'` is erased at emit, so the transform
  // still receives `ts` injected at runtime (tsserver hands the plugin its own
  // copy) — we only borrow TypeScript's types at compile time.
  //
  // noImplicitAny is off for the first port: the AST-walking locals stay inferred
  // so the diff is "add the data-model types", not a wholesale annotation churn.
  // Tighten in a later pass.
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["transform.cts"]
}
