{
  "name": "tsrx-vscode",
  "displayName": "TSRx (live types)",
  "description": "Live TypeScript types for .tsrx files (imperative observables).",
  "version": "0.0.18",
  "publisher": "alden12",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alden12/rxfm.git",
    "directory": "tsrx/vscode-extension"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icons/icon.png",
  "main": "./extension.cjs",
  "activationEvents": [
    "onLanguage:tsrx"
  ],
  "contributes": {
    "languages": [
      {
        "id": "tsrx",
        "aliases": [
          "TSRX"
        ],
        "extensions": [
          ".tsrx"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/tsrx.svg",
          "dark": "./icons/tsrx.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "tsrx",
        "scopeName": "source.tsrx",
        "path": "./TypeScript.tmLanguage.json"
      }
    ],
    "typescriptServerPlugins": [
      {
        "name": "tsrx-ts-plugin",
        "enableForWorkspaceTypeScriptVersions": true,
        "languages": [
          "tsrx"
        ]
      }
    ]
  },
  "scripts": {
    "build": "node ./build.mjs",
    "vscode:prepublish": "node ./build.mjs",
    "clean": "rm -f tsrx-vscode-*.vsix",
    "package": "npm run clean && vsce package",
    "reinstall": "npm run package && code --install-extension \"$(ls -t tsrx-vscode-*.vsix | head -1)\"",
    "bump": "npm version patch --no-git-tag-version"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0"
  }
}
