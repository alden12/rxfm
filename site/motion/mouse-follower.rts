import { Div, State } from "corrente";

import "./mouse-follower-styles.css";

export const MouseFollower = () => {
  const pos = new State({ x: 0, y: 0 });

  return Div
    .class("follower-pad")
    .onMousemove(e => pos.next({ x: e.offsetX, y: e.offsetY }))(
      Div.class("follower-dot").style({ transform: `translate(${pos.x}px, ${pos.y}px)` })``,
    );
};
