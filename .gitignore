node_modules
.DS_Store
/dist/*
/dist-demo/*
/tsrx/dist-tsrx/
# Compiled tsrx plugin output. The .cts sources are the source of truth; every
# consumer regenerates these (pretest + build:tsrx for tests, build.mjs for the
# extension bundle), so tracking them only invites stale-artifact drift.
/tsrx/ts-plugin/*.cjs
*.tgz
*.vsix
# …except the published tsrx extension build, committed so it can be sideloaded
# straight from a clone (see tsrx/vscode-extension/README.md).
!/tsrx/vscode-extension/*.vsix

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
