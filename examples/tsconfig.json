{
  // Governs the example sources, including `.rts` files in the editor. Mirrors
  // reactive-ts/tsconfig.json: the root tsconfig excludes `examples/`, which would
  // otherwise leave `.rts` files in an inferred project with default options (no
  // `paths`, unreliable extraFileExtensions wiring), so the Reactive TS tsserver
  // plugin's virtual TypeScript never type-checked properly. This pins the same
  // options the transform itself uses (see reactive-ts/ts-plugin/transform.cjs
  // `getCompilerOptions`) plus the `rxfm` path. The generated `render` import and the
  // hand-written `accumulate`/`interval`/`EMPTY` imports both resolve to `examples/runtime.ts`.
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "rxfm": ["../src/lib/rxfm/index"]
    }
  },
  "include": ["**/*.rts", "**/*.ts"],
  "exclude": ["node_modules"]
}
